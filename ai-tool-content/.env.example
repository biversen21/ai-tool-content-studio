# Copy to .env and fill in.

# --- Backend ---
NODE_ENV=development
PORT=4000

# Prisma / SQLite
# Path is relative to the prisma/schema.prisma file.
DATABASE_URL="file:./dev.db"

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local export root (relative to repo root)
EXPORT_DIR=exports

# Vite dev proxy target — must match PORT above. Not VITE_ prefixed so it
# is NOT embedded in the frontend bundle (requests go through the dev proxy).
BACKEND_URL=http://localhost:4000
