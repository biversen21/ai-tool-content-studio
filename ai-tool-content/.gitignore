# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# Local databases — never commit
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal
*.sqlite
*.sqlite3

# Generated Prisma client artifacts (regenerated on install)
shared/.prisma/
backend/.prisma/

# Editor / OS
.DS_Store
.vscode/
.idea/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local exports (keep folders, ignore generated content)
exports/json/*
!exports/json/.gitkeep
exports/markdown/*
!exports/markdown/.gitkeep
